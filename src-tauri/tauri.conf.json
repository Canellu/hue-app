{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hue Desktop",
  "version": "0.1.0",
  "identifier": "com.canellu.hue-desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hue Desktop",
        "width": 1200,
        "height": 1200,
        "minWidth": 627,
        "minHeight": 800,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Hue Desktop",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
