# Copy this file to `.env.development` (or `.env.local`) and adjust as needed.
# NOTE: This app has no secret keys here. The Hue application key / bridge
# credentials are paired at runtime and stored securely in the OS keyring
# (see src-tauri/src/services/hue_client.rs), never in env files.

# Enables the in-app dev view switcher / wizard dev toolbar. DEV builds only.
# Accepts "1" or "true".
VITE_DEV_VIEWS=1
