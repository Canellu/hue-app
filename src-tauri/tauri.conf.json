{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hue-app",
  "version": "0.1.0",
  "identifier": "com.anton.hue-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hue-app",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 720,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
